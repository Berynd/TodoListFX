<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="613.0" prefWidth="329.0" spacing="20.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="appli.accueil.loginController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="TItre" contentDisplay="CENTER" text="Bonjours" textAlignment="CENTER">
        <font>
            <Font size="28.0" />
        </font></Label>
    <Label fx:id="EmailText" text="Email :" />
    <TextField fx:id="textEmail" prefHeight="26.0" prefWidth="306.0" />
    <Label fx:id="MDPtexte" text="MDP :" textFill="#0a0909" />
    <PasswordField fx:id="textMDP" />
    <Label fx:id="labelErreur" text="Label erreur" textAlignment="CENTER" textFill="#fc0000" />
    <Button fx:id="BouttonConnexion" onAction="#onConnexionButtonClick" text="Connexion" />
    <Button fx:id="BouttonMDPoublie" mnemonicParsing="false" onAction="#onMdpOublieButtonClick" text="MDP oublié" />
    <Button fx:id="BouttonIsci" mnemonicParsing="false" onAction="#onInscriptionButtonClick" text="Inscription" />
</VBox>
